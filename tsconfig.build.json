{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler"
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.tsx",
    "style-tokens.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "**/*.preview.tsx",
    "**/*.docs.md",
    "app/**",
    "scripts/**",
    "packages/**",
    "lib/**"
  ]
}
