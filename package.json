{
  "name": "@309-thingspire/dsg",
  "version": "0.1.0",
  "description": "Thingspire design library — 44 React components + 2,278 tree-shakable icons + design tokens.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "postbuild": "node scripts/generate-registry.mjs",
    "icons:components": "node scripts/generate-icon-components.mjs",
    "lib:barrel": "node scripts/generate-barrel.mjs",
    "lib:build": "npm run lib:barrel && tsup && cp styles/tokens.css dist/tokens.css",
    "lib:typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepack": "npm run lib:typecheck && npm run lib:build"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "thingspire",
    "icons"
  ],
  "author": "Thingspire",
  "license": "MIT",
  "homepage": "https://thingspire-dsg.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/309-thingspire/thingspire-dsg.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  }
}
